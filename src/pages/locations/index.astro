---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Locations We Serve | Fill & Haul — East Valley, AZ";
const pageDescription = "Fill & Haul provides junk removal and hauling services throughout the East Valley including Phoenix, Scottsdale, Tempe, Mesa, Chandler, and Gilbert, AZ. Find your city.";

const cities = [
  {
    name: "Tempe",
    pillar: "/tempe-hauling-services/",
    city: "/tempe/",
    services: [
      { title: "Junk Removal", href: "/tempe/junk-removal/" },
      { title: "Debris Removal", href: "/tempe/debris-removal/" },
      { title: "Yard Waste Hauling", href: "/tempe/yard-waste-hauling/" },
      { title: "Construction Debris", href: "/tempe/construction-debris-removal/" },
      { title: "Furniture & Appliances", href: "/tempe/furniture-appliance-removal/" },
    ]
  },
  {
    name: "Phoenix",
    pillar: "/phoenix-hauling-services/",
    city: "/phoenix/",
    services: [
      { title: "Junk Removal", href: "/phoenix/junk-removal/" },
      { title: "Debris Removal", href: "/phoenix/debris-removal/" },
      { title: "Yard Waste Hauling", href: "/phoenix/yard-waste-hauling/" },
      { title: "Construction Debris", href: "/phoenix/construction-debris-removal/" },
      { title: "Furniture & Appliances", href: "/phoenix/furniture-appliance-removal/" },
    ]
  },
  {
    name: "Scottsdale",
    pillar: "/scottsdale-hauling-services/",
    city: "/scottsdale/",
    services: [
      { title: "Junk Removal", href: "/scottsdale/junk-removal/" },
      { title: "Debris Removal", href: "/scottsdale/debris-removal/" },
      { title: "Yard Waste Hauling", href: "/scottsdale/yard-waste-hauling/" },
      { title: "Construction Debris", href: "/scottsdale/construction-debris-removal/" },
      { title: "Furniture & Appliances", href: "/scottsdale/furniture-appliance-removal/" },
    ]
  },
  {
    name: "Mesa",
    pillar: "/mesa-hauling-services/",
    city: "/mesa/",
    services: [
      { title: "Junk Removal", href: "/mesa/junk-removal/" },
      { title: "Debris Removal", href: "/mesa/debris-removal/" },
      { title: "Yard Waste Hauling", href: "/mesa/yard-waste-hauling/" },
      { title: "Construction Debris", href: "/mesa/construction-debris-removal/" },
      { title: "Furniture & Appliances", href: "/mesa/furniture-appliance-removal/" },
    ]
  },
  {
    name: "Chandler",
    pillar: "/chandler-hauling-services/",
    city: "/chandler/",
    services: [
      { title: "Junk Removal", href: "/chandler/junk-removal/" },
      { title: "Debris Removal", href: "/chandler/debris-removal/" },
      { title: "Yard Waste Hauling", href: "/chandler/yard-waste-hauling/" },
      { title: "Construction Debris", href: "/chandler/construction-debris-removal/" },
      { title: "Furniture & Appliances", href: "/chandler/furniture-appliance-removal/" },
    ]
  },
  {
    name: "Gilbert",
    pillar: "/gilbert-hauling-services/",
    city: "/gilbert/",
    services: [
      { title: "Junk Removal", href: "/gilbert/junk-removal/" },
      { title: "Debris Removal", href: "/gilbert/debris-removal/" },
      { title: "Yard Waste Hauling", href: "/gilbert/yard-waste-hauling/" },
      { title: "Construction Debris", href: "/gilbert/construction-debris-removal/" },
      { title: "Furniture & Appliances", href: "/gilbert/furniture-appliance-removal/" },
    ]
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Fill & Haul",
      "description": pageDescription,
      "telephone": "+16026325794",
      "url": "https://fillandhaul.com/locations/",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Tempe",
        "addressRegion": "AZ",
        "postalCode": "85281",
        "addressCountry": "US"
      },
      "areaServed": cities.map(c => ({
        "@type": "City",
        "name": c.name,
        "containedInPlace": { "@type": "State", "name": "Arizona" }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Locations", "item": "https://fillandhaul.com/locations/" }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-navy-500">
        <li><a href="/" class="hover:text-brand-500 transition">Home</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-navy-800 font-medium">Locations We Serve</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative py-20 lg:py-28 text-white" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-widest mb-4">East Valley, AZ</p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        Locations<br/>
        <span class="text-brand-400">We Serve</span>
      </h1>
      <p class="text-white/80 text-xl mb-10 max-w-2xl mx-auto">
        Fill & Haul provides professional junk removal and hauling services throughout the East Valley. Find your city below to explore our services.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- City Cards -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4 text-center">Browse by City</h2>
      <p class="text-navy-600 text-center mb-12 max-w-2xl mx-auto">Select your city for a complete guide to our local hauling and junk removal services.</p>

      <div class="space-y-10">
        {cities.map(city => (
          <div class="bg-gray-50 rounded-2xl border border-navy-100 p-6">
            <div class="flex items-center justify-between mb-4">
              <h3 class="font-heading text-2xl font-extrabold text-navy-900">{city.name}, AZ</h3>
              <a href={city.pillar} class="bg-brand-500 text-white font-semibold px-5 py-2 rounded-xl hover:bg-brand-600 transition text-sm">View All {city.name} Services &rarr;</a>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-3">
              {city.services.map(s => (
                <a href={s.href} class="bg-white border border-navy-100 rounded-xl p-3 text-center hover:border-brand-300 hover:shadow-sm transition">
                  <span class="font-semibold text-navy-800 text-sm">{s.title}</span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Also Serving -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">Also Serving the Greater Phoenix Area</h2>
      <p class="text-navy-600 mb-6">In addition to our primary service cities, Fill & Haul covers <strong>Glendale, Peoria, Surprise, Goodyear, Buckeye, Avondale,</strong> and surrounding Maricopa County communities. If you don't see your city listed above, <a href="/#contact" class="text-brand-500 hover:underline">contact us</a> — we likely cover your area.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Ready to Schedule Junk Removal?</h2>
      <p class="text-white/90 text-lg mb-8">Same-day service available throughout the East Valley. Licensed, insured, and eco-friendly.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
