---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Gilbert, AZ Hauling & Junk Removal Services | Fill & Haul";
const pageDescription = "Professional junk removal and hauling in Gilbert, AZ. Fill & Haul offers fast, affordable same-day service for homes and businesses throughout Gilbert. Free estimates. Call (602) 632-5794.";

const faqs = [
  { q: "What hauling services do you offer in Gilbert, AZ?", a: "Fill & Haul offers junk removal, debris removal, yard waste hauling, construction debris removal, and furniture & appliance removal throughout Gilbert including Val Vista Lakes, Power Ranch, Morrison Ranch, Agritopia, and all surrounding neighborhoods." },
  { q: "Do you offer same-day junk removal in Gilbert?", a: "Yes! We offer same-day and next-day junk removal throughout Gilbert (85233, 85234, 85295, 85296, 85297, 85298). Call (602) 632-5794 to schedule your pickup." },
  { q: "How much does hauling cost in Gilbert, AZ?", a: "Most Gilbert jobs range from $150 for small loads to $600+ for full property cleanouts. We provide free on-site estimates before any work begins. Pricing is transparent with no hidden fees." },
  { q: "Are you licensed and insured to haul in Gilbert?", a: "Yes, Fill & Haul is fully licensed and insured to operate throughout Gilbert and the greater East Valley. We comply with all local disposal and recycling regulations." },
  { q: "What areas of Gilbert do you serve?", a: "We serve all of Gilbert including Val Vista Lakes, Finley Farms, Power Ranch, Morrison Ranch, Agritopia, Higley, and all zip codes 85233-85298. We also serve neighboring Queen Creek, Chandler, and Mesa." }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "name": "Fill & Haul",
      "description": pageDescription,
      "telephone": "+16026325794",
      "url": "https://fillandhaul.com/gilbert-hauling-services/",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Tempe",
        "addressRegion": "AZ",
        "postalCode": "85281",
        "addressCountry": "US"
      },
      "areaServed": {
        "@type": "City",
        "name": "Gilbert",
        "containedInPlace": { "@type": "State", "name": "Arizona" }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Gilbert Hauling Services", "item": "https://fillandhaul.com/gilbert-hauling-services/" }
      ]
    }
  ]
};

const services = [
  { title: 'Junk Removal', href: '/gilbert/junk-removal/', desc: 'Full-service junk pickup from homes and businesses throughout Gilbert.' },
  { title: 'Debris Removal', href: '/gilbert/debris-removal/', desc: 'Fast debris haul-away for cleanup projects in Gilbert.' },
  { title: 'Yard Waste Hauling', href: '/gilbert/yard-waste-hauling/', desc: 'Tree trimmings, grass clippings, and landscaping debris removed.' },
  { title: 'Construction Debris Removal', href: '/gilbert/construction-debris-removal/', desc: 'Drywall, lumber, concrete, roofing, and renovation waste hauled away.' },
  { title: 'Furniture & Appliance Removal', href: '/gilbert/furniture-appliance-removal/', desc: 'Old sofas, beds, fridges, washers, and more removed quickly.' },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-navy-500">
        <li><a href="/" class="hover:text-brand-500 transition">Home</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-navy-800 font-medium">Gilbert Hauling Services</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative py-20 lg:py-28 text-white" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-widest mb-4">Gilbert, AZ</p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        Gilbert Hauling &<br/>
        <span class="text-brand-400">Junk Removal Services</span>
      </h1>
      <p class="text-white/80 text-xl mb-10 max-w-2xl mx-auto">
        Fast, affordable junk removal and hauling throughout Gilbert, AZ. Same-day service in Val Vista Lakes, Power Ranch, Morrison Ranch, Agritopia, and all Gilbert neighborhoods.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4 text-center">Gilbert Hauling Services We Offer</h2>
      <p class="text-navy-600 text-center mb-10 max-w-2xl mx-auto">From single-item pickups to full property cleanouts, Fill & Haul handles it all in Gilbert.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <a href={s.href} class="bg-gray-50 border border-navy-100 rounded-2xl p-6 hover:border-brand-300 hover:shadow-md transition group">
            <h3 class="font-heading text-lg font-bold text-navy-900 mb-2 group-hover:text-brand-600 transition">{s.title}</h3>
            <p class="text-navy-600 text-sm">{s.desc}</p>
            <span class="mt-4 inline-flex items-center text-brand-500 font-semibold text-sm">Learn more &rarr;</span>
          </a>
        ))}
        <a href="/gilbert/" class="bg-brand-500 rounded-2xl p-6 hover:bg-brand-600 transition group">
          <h3 class="font-heading text-lg font-bold text-white mb-2">All Gilbert Services</h3>
          <p class="text-white/80 text-sm">View all junk removal and hauling services available in Gilbert, AZ.</p>
          <span class="mt-4 inline-flex items-center text-white font-semibold text-sm">View all &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4 text-center">Why Gilbert Residents Choose Fill & Haul</h2>
      <div class="grid sm:grid-cols-2 gap-4 mt-8">
        {[
          "Same-day and next-day pickup throughout Gilbert",
          "Flat-rate transparent pricing — no surprise charges",
          "Licensed and insured professionals",
          "Eco-friendly disposal and recycling",
          "Heavy-load capability for any size job",
          "Serving Val Vista Lakes, Power Ranch, Agritopia & more"
        ].map(item => (
          <div class="flex items-center gap-3 bg-white rounded-xl px-5 py-4 border border-gray-100">
            <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span class="text-navy-800 font-medium">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">Gilbert Neighborhoods We Serve</h2>
      <p class="text-navy-600 mb-6">Fill & Haul provides junk removal and hauling throughout all of Gilbert including <strong>Val Vista Lakes, Finley Farms, Power Ranch, Morrison Ranch, Agritopia,</strong> and <strong>Higley</strong>. Zip codes served: 85233, 85234, 85295, 85296, 85297, 85298.</p>
      <p class="text-navy-600">We also serve nearby <a href="/chandler-hauling-services/" class="text-brand-500 hover:underline">Chandler</a>, <a href="/mesa-hauling-services/" class="text-brand-500 hover:underline">Mesa</a>, <a href="/tempe-hauling-services/" class="text-brand-500 hover:underline">Tempe</a>, and <a href="/phoenix-hauling-services/" class="text-brand-500 hover:underline">Phoenix</a>.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Gilbert Hauling Services FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-white rounded-2xl border border-navy-100 overflow-hidden">
            <summary class="list-none flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-navy-900">{f.q}<svg class="w-5 h-5 text-brand-500 flex-shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
            <div class="px-6 pb-4 text-navy-500 text-sm">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Book Junk Removal in Gilbert Today</h2>
      <p class="text-white/90 text-lg mb-8">Same-day service available. Licensed, insured, and eco-friendly throughout Gilbert, AZ.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
