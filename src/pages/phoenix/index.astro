---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Junk Removal Phoenix AZ | Same-Day Hauling | Fill & Haul';
const pageDescription = 'Professional junk removal and hauling in Phoenix, AZ. Fill & Haul serves the Phoenix metro with fast, affordable same-day service. Furniture, appliances, construction debris, estate cleanouts, and more. Free estimates.';

const faqs = [
  { q: 'Do you offer junk removal in Phoenix, AZ?', a: 'Yes! Fill & Haul serves Phoenix and the greater Phoenix metro area including Central Phoenix, North Phoenix, South Phoenix, and surrounding neighborhoods. Same-day service available.' },
  { q: 'How much does junk removal cost in Phoenix?', a: 'Phoenix junk removal typically ranges from $150 for small loads to $700+ for large cleanouts. We offer free on-site estimates with no obligation before any work begins.' },
  { q: 'What Phoenix neighborhoods do you serve?', a: 'We serve all of Phoenix including Arcadia, Ahwatukee, Biltmore, Camelback East, Central City, Deer Valley, Maryvale, North Mountain, Paradise Valley Village, and more.' },
  { q: 'Do you haul commercial junk in Phoenix?', a: 'Absolutely. We handle office cleanouts, warehouse cleanups, retail space clearing, and all types of commercial junk removal throughout Phoenix.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Junk Removal in Phoenix, AZ",
      "provider": { "@type": "LocalBusiness", "name": "Fill & Haul", "telephone": "+16026325794" },
      "areaServed": { "@type": "City", "name": "Phoenix, Arizona" },
      "description": pageDescription,
      "url": "https://fillandhaul.com/phoenix/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question", "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Phoenix Junk Removal", "item": "https://fillandhaul.com/phoenix/" }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />
  <nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-brand-600 transition">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-navy-700 font-medium">Phoenix Junk Removal</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-navy-900 text-white py-20" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 text-center lg:text-left">
          Junk Removal in <span class="text-brand-400">Phoenix, AZ</span>
        </h1>
        <p class="text-xl text-navy-200 mb-8 text-center lg:text-left">Phoenix's trusted junk removal and hauling service. We remove furniture, appliances, construction debris, yard waste, and more - same-day service available across all of Phoenix and the Valley.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="/#contact" class="inline-flex items-center justify-center bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl transition text-lg">Get a Free Estimate</a>
          <a href="tel:+16026325794" class="inline-flex items-center justify-center border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-xl transition text-lg">(602) 632-5794</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-navy-900 mb-4">Phoenix's Reliable Junk Removal Company</h2>
        <p class="text-navy-500 text-lg max-w-2xl mx-auto">From residential cleanouts to commercial haul-aways, Fill & Haul delivers fast, professional junk removal across the Phoenix metro.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '&#128336;', title: 'Same-Day Service', desc: 'Call before noon and we can often arrive at your Phoenix property the same day.' },
          { icon: '&#128176;', title: 'Upfront Pricing', desc: 'Free on-site estimates. You know the price before we start loading.' },
          { icon: '&#9989;', title: 'Licensed & Insured', desc: 'Fully licensed and insured for residential and commercial work in Phoenix.' },
          { icon: '&#127807;', title: 'Eco-Friendly Disposal', desc: 'We donate and recycle to keep as much as possible out of Phoenix landfills.' },
        ].map(item => (
          <div class="bg-gray-50 rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3" set:html={item.icon}></div>
            <h3 class="font-heading font-bold text-lg text-navy-900 mb-2">{item.title}</h3>
            <p class="text-navy-500 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">What We Haul in Phoenix</h2>
        <p class="text-navy-500 text-lg">Comprehensive junk removal for Phoenix homes, businesses, and properties.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Furniture Removal', desc: 'Sofas, beds, dressers, tables - we clear any furniture from Phoenix homes and offices.' },
          { title: 'Appliance Hauling', desc: 'Refrigerators, washers, dryers, and ovens removed safely and responsibly from Phoenix.' },
          { title: 'Construction Debris', desc: 'Drywall, lumber, concrete, roofing - fast job site cleanup for Phoenix contractors.' },
          { title: 'Yard Waste Hauling', desc: 'Tree branches, landscaping waste, rocks, and dirt hauled away from Phoenix properties.' },
          { title: 'Estate & Property Cleanouts', desc: 'Full estate cleanouts and property cleanups throughout the Phoenix metro area.' },
          { title: 'Commercial Junk Removal', desc: 'Office cleanouts, warehouse cleanup, and commercial hauling across Phoenix.' },
        ].map(s => (
          <div class="bg-white border border-navy-100 rounded-2xl p-6 hover:shadow-md transition">
            <h3 class="font-heading font-bold text-lg text-navy-900 mb-2">{s.title}</h3>
            <p class="text-navy-500 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">Serving All of Phoenix, AZ</h2>
        <p class="text-navy-500 text-lg mb-6">We cover all Phoenix zip codes including 85001-85021 and all neighborhoods from Downtown to North Phoenix, Arcadia, Ahwatukee, and everything in between.</p>
        <p class="text-navy-500">Also serving: <a href="/scottsdale/" class="text-brand-600 hover:underline">Scottsdale</a>, <a href="/tempe/" class="text-brand-600 hover:underline">Tempe</a>, <a href="/mesa/" class="text-brand-600 hover:underline">Mesa</a>, <a href="/chandler/" class="text-brand-600 hover:underline">Chandler</a>, and <a href="/gilbert/" class="text-brand-600 hover:underline">Gilbert</a>.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Phoenix Junk Removal FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="bg-white rounded-2xl p-6 border border-navy-100">
            <h3 class="font-semibold text-navy-900 mb-2">{f.q}</h3>
            <p class="text-navy-500 text-sm">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Need Junk Removed in Phoenix Today?</h2>
      <p class="text-white/90 text-lg mb-8">Call or text us now. Same-day service available across Phoenix and the entire Valley.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
