---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

const pageTitle = 'Furniture & Appliance Removal Phoenix AZ | Fill & Haul';
const pageDescription = 'Professional furniture and appliance removal in Phoenix, AZ. Fill & Haul hauls away sofas, refrigerators, washers, dryers, mattresses, and more. Same-day service available. Free estimates.';

const faqs = [
  { q: 'Do you remove furniture from inside my Phoenix home?', a: 'Yes! Our crew will enter your home, garage, or storage unit and carry items out from wherever they are. No need to move anything to the curb beforehand.' },
  { q: 'What appliances do you remove in Phoenix?', a: 'We remove refrigerators, washers, dryers, dishwashers, ovens, stoves, microwaves, water heaters, and most large household appliances throughout Phoenix.' },
  { q: 'How much does furniture removal cost in Phoenix?', a: 'Furniture and appliance removal in Phoenix typically costs $100-$500 depending on the number and size of items. We offer free on-site estimates before any work begins.' },
  { q: 'Do you recycle old appliances in Phoenix?', a: 'Yes! We work with local recyclers to ensure refrigerants are properly recovered and metal is recycled. We keep as much as possible out of Phoenix landfills.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Furniture and Appliance Removal in Phoenix, AZ",
      "provider": { "@type": "LocalBusiness", "name": "Fill & Haul", "telephone": "+16026325794" },
      "areaServed": { "@type": "City", "name": "Phoenix, Arizona" },
      "description": pageDescription,
      "url": "https://fillandhaul.com/phoenix/furniture-appliance-removal/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question", "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Phoenix Hauling Services", "item": "https://fillandhaul.com/phoenix-hauling-services/" },
        { "@type": "ListItem", "position": 3, "name": "Furniture & Appliance Removal", "item": "https://fillandhaul.com/phoenix/furniture-appliance-removal/" }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-brand-600 transition">Home</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/phoenix-hauling-services/" class="hover:text-brand-600 transition">Phoenix Hauling Services</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-700 font-medium">Furniture &amp; Appliance Removal</li>
      </ol>
    </div>
  </nav>

  <section class="bg-navy-900 text-white py-20" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 text-center lg:text-left">
        Furniture &amp; Appliance Removal in <span class="text-brand-400">Phoenix, AZ</span>
      </h1>
      <p class="text-xl text-navy-200 mb-8 text-center lg:text-left">Fast, professional furniture and appliance removal for Phoenix homeowners. We haul away sofas, mattresses, refrigerators, washers, and anything else you need gone.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <a href="/#contact" class="inline-flex items-center justify-center bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl transition text-lg">Get a Free Estimate</a>
        <a href="tel:+16026325794" class="inline-flex items-center justify-center border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">(602) 632-5794</a>
      </div>
    </div>
  </section>

  <main class="bg-white">
    <section class="py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-4xl mx-auto space-y-6 text-gray-600">
          <h2 class="font-heading text-3xl font-bold text-navy-900 pt-4">Phoenix Furniture &amp; Appliance Pickup Made Easy</h2>
          <p>Fill &amp; Haul makes furniture and appliance removal in Phoenix simple. Our two-person crews handle all the heavy lifting, carrying items from wherever they are in your home and loading them onto our truck.</p>
          <p>Whether you're replacing old appliances after a renovation, upgrading kitchen appliances, preparing for a move, or handling an estate cleanout, we're the team Phoenix homeowners trust for fast, reliable pickup.</p>
          <p>We serve all Phoenix neighborhoods including Arcadia, Ahwatukee, Biltmore, Camelback, Deer Valley, North Phoenix, South Phoenix, and everywhere in between with flexible same-day and next-day scheduling.</p>
        </div>

        <h2 class="font-heading text-3xl font-bold text-navy-900 pt-4">Furniture &amp; Appliances We Remove in Phoenix</h2>
        <div class="grid sm:grid-cols-2 gap-3 not-prose">
          {['Sofas, sectionals, and loveseats', 'Beds, frames, and mattresses', 'Dressers, wardrobes, and armoires', 'Dining sets and kitchen tables', 'Refrigerators and freezers', 'Washers and dryers', 'Dishwashers and ovens', 'Water heaters and HVAC units', 'Desks, bookshelves, and office furniture', 'Hot tubs and outdoor furniture'].map(item => (
            <div class="flex items-start gap-2 text-sm bg-gray-50 rounded-lg p-3">
              <svg class="w-5 h-5 text-brand-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
              {item}
            </div>
          ))}
        </div>

        <h2 class="font-heading text-3xl font-bold text-navy-900 pt-4">When Phoenix Residents Call Us for Furniture &amp; Appliance Removal</h2>
        <p>Here are the most common situations where Phoenix homeowners reach out to Fill &amp; Haul:</p>
        <ul class="space-y-2 list-disc list-inside">
          <li>Replacing old appliances with new ones after delivery is scheduled</li>
          <li>Downsizing or moving to a smaller home and need to shed furniture</li>
          <li>Handling an estate and need multiple rooms cleared quickly</li>
          <li>Clearing out a rental property between tenants</li>
          <li>Getting rid of old exercise equipment taking up garage space</li>
        </ul>

        <h2 class="font-heading text-3xl font-bold text-navy-900 pt-4">Our Furniture &amp; Appliance Removal Process in Phoenix</h2>
        <ol class="space-y-4 list-none">
          {[
            { n: '1', t: 'Schedule Your Pickup', d: 'Call (602) 632-5794 or request online. We confirm availability and provide a free estimate based on what you need removed.' },
            { n: '2', t: 'We Do the Heavy Lifting', d: 'Our two-person crew arrives at your Phoenix property, carries everything from wherever it is, and loads it onto our truck. You do not lift a finger.' },
            { n: '3', t: 'Donate, Recycle, Dispose', d: 'Usable furniture gets donated to local Phoenix-area charities. Appliances are recycled responsibly. The rest is properly disposed of at licensed facilities.' },
          ].map(s => (
            <li class="flex gap-4 bg-gray-50 rounded-xl p-5">
              <span class="w-10 h-10 bg-brand-500 text-white rounded-lg flex items-center justify-center font-bold text-lg flex-shrink-0">{s.n}</span>
              <div>
                <strong class="text-navy-900">{s.t}</strong>
                <p class="text-sm mt-1">{s.d}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-2xl font-bold text-navy-900 mb-6 text-center">Frequently Asked Questions</h2>
        <div class="max-w-3xl mx-auto space-y-3">
          {faqs.map(faq => (
            <details class="group bg-white rounded-xl shadow-sm border border-gray-100">
              <summary class="list-none flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-navy-900">
                {faq.q}
                <svg class="w-5 h-5 text-gray-400 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="px-6 pb-5 text-gray-600 text-sm border-t border-gray-100 pt-4">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 bg-white border-t border-gray-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-2xl font-bold text-navy-900 mb-6 text-center">Related Phoenix Services</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <a href="/phoenix-hauling-services/" class="text-center p-4 rounded-xl border border-gray-200 hover:border-brand-400 hover:bg-brand-50 transition text-sm font-semibold text-navy-700 hover:text-brand-700">All Phoenix Services</a>
          <a href="/phoenix/junk-removal/" class="text-center p-4 rounded-xl border border-gray-200 hover:border-brand-400 hover:bg-brand-50 transition text-sm font-semibold text-navy-700 hover:text-brand-700">Junk Removal</a>
          <a href="/phoenix/debris-removal/" class="text-center p-4 rounded-xl border border-gray-200 hover:border-brand-400 hover:bg-brand-50 transition text-sm font-semibold text-navy-700 hover:text-brand-700">Debris Removal</a>
          <a href="/phoenix/yard-waste-hauling/" class="text-center p-4 rounded-xl border border-gray-200 hover:border-brand-400 hover:bg-brand-50 transition text-sm font-semibold text-navy-700 hover:text-brand-700">Yard Waste Hauling</a>
        </div>
      </div>
    </section>

    <section class="py-16 bg-brand-500">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-heading text-3xl font-bold text-white mb-4">Ready to Remove Furniture or Appliances in Phoenix?</h2>
        <p class="text-xl text-white/80 mb-8">Get a free estimate today. Same-day service available across Phoenix.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/#contact" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">Get a Free Estimate</a>
          <a href="tel:+16026325794" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">(602) 632-5794</a>
        </div>
      </div>
    </section>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Footer />
</Layout>
