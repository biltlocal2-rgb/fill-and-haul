---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = "Junk Removal Blog | Tips, Guides & Resources | Fill & Haul Tempe";
const pageDescription = "Expert tips on junk removal, debris disposal, eco-friendly hauling, estate cleanouts, and cost guides for Tempe and the East Valley. Browse all articles from Fill & Haul.";

const categories = [
  { id: 'all', label: 'All Posts', color: 'bg-gray-200 text-gray-800' },
  { id: 'preparation', label: 'Preparation', color: 'bg-blue-100 text-blue-800' },
  { id: 'costs', label: 'Costs & Comparisons', color: 'bg-green-100 text-green-800' },
  { id: 'eco', label: 'Eco & Environment', color: 'bg-emerald-100 text-emerald-800' },
  { id: 'specialty', label: 'Specialty Removal', color: 'bg-purple-100 text-purple-800' },
  { id: 'local', label: 'Local Guides', color: 'bg-orange-100 text-orange-800' },
