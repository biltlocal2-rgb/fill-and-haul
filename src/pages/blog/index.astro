    categoryColor: 'bg-orange-100 text-orange-800',
    readTime: '7 min read',
    date: 'March 2025',
    icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Blog",
      "@id": "https://fillandhaul.com/blog/",
      "name": "Fill and Haul Blog",
      "description": "Expert junk removal tips, cost guides, eco-friendly disposal, and local hauling resources for Tempe and the East Valley.",
      "url": "https://fillandhaul.com/blog/",
      "publisher": {
        "@type": "LocalBusiness",
        "name": "Fill and Haul",
        "url": "https://fillandhaul.com",
        "telephone": "+16026325794",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Tempe",
          "addressRegion": "AZ",
          "addressCountry": "US"
        }
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://fillandhaul.com/blog/" }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-brand-500 transition">Home</a></li>
        <li><span class="mx-1 text-gray-300">/</span></li>
        <li class="text-gray-900 font-medium">Blog</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 py-20 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 bg-brand-500/20 text-brand-400 text-sm font-semibold px-4 py-2 rounded-full mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
        Resources and Guides
      </div>
      <h1 class="text-4xl sm:text-5xl font-heading font-extrabold mb-6 leading-tight">
        The Fill &amp; Haul <span class="text-brand-400">Blog</span>
      </h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        Expert guides on junk removal, eco-friendly disposal, cost breakdowns, and local resources for Tempe and the East Valley.
      </p>
    </div>
  </section>

  <!-- Category Filter Bar -->
  <section class="bg-white border-b border-gray-200 sticky top-16 lg:top-20 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex items-center gap-2 overflow-x-auto pb-1 no-scrollbar" id="category-filters">
        {categories.map(cat => (
          <button
            data-category={cat.id}
            class={`category-btn flex-shrink-0 px-4 py-2 rounded-full text-sm font-semibold transition ${cat.id === 'all' ? 'bg-brand-500 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}`}
          >
            {cat.label}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Posts by Category -->
  <main class="bg-gray-50 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

      {['preparation', 'costs', 'eco', 'specialty', 'local'].map(catId => {
        const catMeta = categories.find(c => c.id === catId);
        const catPosts = posts.filter(p => p.category === catId);
        const barColor = catId === 'preparation' ? 'bg-blue-400' : catId === 'costs' ? 'bg-green-400' : catId === 'eco' ? 'bg-emerald-400' : catId === 'specialty' ? 'bg-purple-400' : 'bg-brand-500';
        return (
          <div class="category-section mb-16" data-section={catId}>
            <div class="flex items-center gap-3 mb-8">
              <span class={`px-3 py-1 rounded-full text-sm font-bold ${catPosts[0]?.categoryColor ?? 'bg-gray-100 text-gray-700'}`}>{catMeta?.label}</span>
              <div class="flex-1 h-px bg-gray-200"></div>
              <span class="text-sm text-gray-400">{catPosts.length} article{catPosts.length !== 1 ? 's' : ''}</span>
            </div>
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
              {catPosts.map(post => (
                <article class="blog-card bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow overflow-hidden group" data-category={post.category}>
                  <div class={`h-1.5 ${barColor}`}></div>
                  <div class="p-6">
                    <div class="flex items-start justify-between mb-4">
                      <div class="w-10 h-10 bg-gray-50 rounded-xl flex items-center justify-center flex-shrink-0">
                        <svg class="w-5 h-5 text-brand-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={post.icon} />
                        </svg>
                      </div>
                      <span class={`px-2.5 py-1 rounded-full text-xs font-semibold ${post.categoryColor}`}>{post.categoryLabel}</span>
                    </div>
                    <h2 class="text-gray-900 font-heading font-bold text-lg leading-snug mb-3 group-hover:text-brand-500 transition-colors">
                      <a href={`/blog/${post.slug}/`} class="blog-post-link">{post.title}</a>
                    </h2>
                    <p class="text-gray-500 text-sm leading-relaxed mb-4">{post.excerpt}</p>
                    <div class="flex items-center justify-between text-xs text-gray-400 pt-4 border-t border-gray-100">
                      <span>{post.date}</span>
                      <span class="flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                        {post.readTime}
                      </span>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
        );
      })}

      <div id="no-results" class="hidden text-center py-20 text-gray-400">
        <svg class="w-12 h-12 mx-auto mb-4 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <p class="font-semibold text-lg">No posts in this category yet</p>
        <p class="text-sm mt-1">Check back soon — we publish new guides regularly.</p>
      </div>

    </div>
  </main>

  <!-- CTA -->
  <section class="bg-brand-500 py-16 text-white text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl font-heading font-extrabold mb-4">Ready to Clear the Clutter?</h2>
      <p class="text-xl text-white/90 mb-8">Same-day junk removal across Tempe and the East Valley. No hidden fees.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#contact" class="bg-white text-brand-500 hover:bg-gray-100 font-bold px-8 py-3.5 rounded-xl transition text-lg">Get a Free Quote</a>
        <a href="tel:+16026325794" class="border-2 border-white text-white hover:bg-white/10 font-bold px-8 py-3.5 rounded-xl transition text-lg">(602) 632-5794</a>
      </div>
    </div>
  </section>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  const filterBtns = document.querySelectorAll('.category-btn');
  const sections = document.querySelectorAll('.category-section');
  const noResults = document.getElementById('no-results');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category');

      filterBtns.forEach(b => {
        b.classList.remove('bg-brand-500', 'text-white', 'shadow-sm');
        b.classList.add('bg-gray-100', 'text-gray-600');
      });
      btn.classList.add('bg-brand-500', 'text-white', 'shadow-sm');
      btn.classList.remove('bg-gray-100', 'text-gray-600');

      let anyVisible = false;
      sections.forEach(section => {
        const el = section as HTMLElement;
        if (cat === 'all' || el.getAttribute('data-section') === cat) {
          el.style.display = '';
          anyVisible = true;
        } else {
          el.style.display = 'none';
        }
      });

      if (noResults) {
        noResults.classList.toggle('hidden', anyVisible);
      }
    });
  });
</script>
