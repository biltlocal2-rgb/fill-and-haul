---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

const pageTitle = "Construction Debris Removal in Chandler, AZ | Fill & Haul";
const pageDescription = "Professional construction debris removal in Chandler, AZ. We haul away drywall, lumber, concrete, roofing materials, and renovation waste. Same-day service. Call (602) 632-5794.";

const faqs = [
  { q: "What types of construction debris do you remove in Chandler?", a: "We remove all common construction debris including drywall, lumber, plywood, roofing shingles, insulation, tile, concrete, masonry, metal framing, flooring materials, and general renovation waste from Chandler job sites." },
  { q: "Do you offer same-day construction debris removal in Chandler?", a: "Yes! We offer same-day and next-day construction debris removal throughout Chandler including Ocotillo, Sun Lakes, Fulton Ranch, and Chandler Heights. Call (602) 632-5794 to schedule." },
  { q: "Can you handle large commercial job sites in Chandler?", a: "Absolutely. Our heavy-load trucks handle large commercial and residential construction projects throughout Chandler's 85224-85249 zip codes. We work around your job site schedule to minimize downtime." },
  { q: "Are you licensed and insured for construction debris hauling in Chandler?", a: "Yes, Fill & Haul is fully licensed and insured to operate throughout Chandler and the greater East Valley. We comply with all local disposal and recycling regulations." },
  { q: "How do I get a quote for construction debris removal in Chandler?", a: "Call us at (602) 632-5794 or fill out our online form for a free estimate. Pricing is based on volume and type of materials. We offer transparent flat-rate pricing with no hidden fees." }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Construction Debris Removal in Chandler, AZ",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Fill & Haul",
        "telephone": "+16026325794",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Tempe",
          "addressRegion": "AZ",
          "postalCode": "85281",
          "addressCountry": "US"
        }
      },
      "areaServed": {
        "@type": "City",
        "name": "Chandler",
        "containedInPlace": { "@type": "State", "name": "Arizona" }
      },
      "description": "Professional construction debris removal in Chandler, AZ including drywall, lumber, concrete, roofing materials, and renovation waste haul-away."
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Chandler Hauling Services", "item": "https://fillandhaul.com/chandler-hauling-services/" },
        { "@type": "ListItem", "position": 3, "name": "Construction Debris Removal", "item": "https://fillandhaul.com/chandler/construction-debris-removal/" }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-navy-500">
        <li><a href="/" class="hover:text-brand-500 transition">Home</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/chandler-hauling-services/" class="hover:text-brand-500 transition">Chandler Hauling Services</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-navy-800 font-medium">Construction Debris Removal</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative py-20 lg:py-28 text-white" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-widest mb-4">Chandler, AZ</p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        Construction Debris Removal<br/>
        <span class="text-brand-400">in Chandler, AZ</span>
      </h1>
      <p class="text-white/80 text-xl mb-10 max-w-2xl mx-auto">
        Fast, reliable haul-away for drywall, lumber, concrete, roofing materials, and all renovation waste. Serving Chandler contractors and homeowners.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- What We Remove -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4 text-center">Construction Debris We Remove in Chandler</h2>
      <p class="text-navy-600 text-center mb-10 max-w-2xl mx-auto">From small bathroom remodels to large commercial builds, we haul it all from your Chandler job site.</p>
      <div class="grid sm:grid-cols-2 gap-4">
        {[
          "Drywall and plaster",
          "Lumber and wood scraps",
          "Roofing shingles and tar paper",
          "Concrete and masonry",
          "Tile and flooring materials",
          "Metal framing and studs",
          "Insulation and batting",
          "Plumbing and electrical scrap",
          "Demo debris and rubble",
          "Packaging and construction wrap"
        ].map(item => (
          <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-5 py-4 border border-gray-100">
            <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span class="text-navy-800 font-medium">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Signs You Need This Service -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Signs You Need Construction Debris Removal</h2>
      <ul class="space-y-4">
        {[
          "Your job site is piling up with debris that's slowing down your crew in Chandler",
          "Your dumpster is full and you can't fit more renovation waste",
          "You've finished a remodel and need all the leftover materials hauled away",
          "You have heavy concrete, tile, or masonry that standard trash pickup won't take",
          "You're preparing a Chandler property for sale and need a clean site fast"
        ].map(sign => (
          <li class="flex items-start gap-3">
            <svg class="w-6 h-6 text-brand-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-navy-700 text-lg">{sign}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4 text-center">How Our Chandler Construction Debris Removal Works</h2>
      <p class="text-navy-600 text-center mb-10">Three simple steps to a clean job site.</p>
      <div class="space-y-6">
        {[
          { step: "1", title: "Book Your Pickup", desc: "Call (602) 632-5794 or fill out our online form. We'll confirm same-day or next-day availability for your Chandler location." },
          { step: "2", title: "We Load & Haul", desc: "Our licensed crew arrives on schedule, loads all construction debris efficiently, and hauls it away. You don't lift a finger." },
          { step: "3", title: "Clean Site, Done", desc: "We dispose of all materials responsibly — recycling what we can. Your Chandler job site is clean and ready for the next phase." }
        ].map(s => (
          <div class="flex items-start gap-5">
            <div class="w-12 h-12 bg-brand-500 rounded-full flex items-center justify-center text-white font-extrabold text-xl flex-shrink-0">{s.step}</div>
            <div>
              <h3 class="font-heading text-xl font-bold text-navy-900 mb-1">{s.title}</h3>
              <p class="text-navy-600">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">Chandler Neighborhoods We Serve</h2>
      <p class="text-navy-600 mb-6">We provide construction debris removal throughout all of Chandler including <strong>Ocotillo, Sun Lakes, Fulton Ranch, Chandler Heights, Alma School Corridor,</strong> and <strong>Pecos Ranch</strong>. Zip codes served: 85224, 85225, 85226, 85244, 85246, 85248, 85249.</p>
      <p class="text-navy-600">We also serve neighboring communities in <a href="/mesa-hauling-services/" class="text-brand-500 hover:underline">Mesa</a>, <a href="/gilbert-hauling-services/" class="text-brand-500 hover:underline">Gilbert</a>, <a href="/tempe-hauling-services/" class="text-brand-500 hover:underline">Tempe</a>, and <a href="/phoenix-hauling-services/" class="text-brand-500 hover:underline">Phoenix</a>.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Chandler Construction Debris FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-white rounded-2xl border border-navy-100 overflow-hidden">
            <summary class="list-none flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-navy-900">{f.q}<svg class="w-5 h-5 text-brand-500 flex-shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
            <div class="px-6 pb-4 text-navy-500 text-sm">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Services -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">More Chandler Hauling Services</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[{ title: 'Chandler Hauling Services', href: '/chandler-hauling-services/' }, { title: 'Junk Removal', href: '/chandler/junk-removal/' }, { title: 'Debris Removal', href: '/chandler/debris-removal/' }, { title: 'Furniture & Appliance Removal', href: '/chandler/furniture-appliance-removal/' }].map(s => (
          <a href={s.href} class="bg-gray-50 border border-navy-100 rounded-xl p-4 text-center hover:border-brand-300 hover:shadow-sm transition"><span class="font-semibold text-navy-800 text-sm">{s.title}</span></a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Schedule Construction Debris Removal in Chandler Today</h2>
      <p class="text-white/90 text-lg mb-8">Fast haul-away for your renovation or construction project. Same-day service available.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
