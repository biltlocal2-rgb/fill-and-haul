---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

const pageTitle = 'Yard Waste Hauling Chandler AZ | Green Waste Removal | Fill & Haul';
const pageDescription = 'Yard waste hauling and green waste removal in Chandler, AZ. Fill & Haul removes tree trimmings, brush, clippings, and organic debris from Chandler yards. Same-day service available.';

const faqs = [
  { q: 'Do you haul yard waste in Chandler?', a: 'Yes! We haul all types of yard and green waste from Chandler properties including tree branches, palm fronds, shrub trimmings, and organic debris.' },
  { q: 'Do you remove palm fronds in Chandler?', a: 'Absolutely. Palm frond and desert plant debris removal is a common service throughout Chandler. We haul any volume quickly.' },
  { q: 'Can you handle large tree trimming debris in Chandler?', a: 'Yes, our heavy-duty trucks are equipped for large loads of tree trimming debris from Chandler properties.' },
  { q: 'Is yard waste responsibly disposed of in Chandler?', a: 'Yes. We sort green waste to composting facilities whenever possible. Fill & Haul is committed to eco-friendly disposal.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Service", "name": "Yard Waste Hauling in Chandler, AZ", "provider": { "@type": "LocalBusiness", "name": "Fill & Haul", "telephone": "+16026325794" }, "areaServed": { "@type": "City", "name": "Chandler, Arizona" }, "description": pageDescription, "url": "https://fillandhaul.com/chandler/yard-waste-hauling/" },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
    { "@type": "BreadcrumbList", "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" }, { "@type": "ListItem", "position": 2, "name": "Chandler", "item": "https://fillandhaul.com/chandler/" }, { "@type": "ListItem", "position": 3, "name": "Yard Waste Hauling", "item": "https://fillandhaul.com/chandler/yard-waste-hauling/" }] }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />
  <nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-brand-600 transition">Home</a></li><li><span class="mx-1">/</span></li>
        <li><a href="/chandler/" class="hover:text-brand-600 transition">Chandler</a></li><li><span class="mx-1">/</span></li>
        <li class="text-navy-700 font-medium">Yard Waste Hauling</li>
      </ol>
    </div>
  </nav>
  <section class="bg-navy-900 text-white py-20" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 text-center lg:text-left">Yard Waste Hauling in <span class="text-brand-400">Chandler, AZ</span></h1>
        <p class="text-xl text-navy-200 mb-8 text-center lg:text-left">Chandler's yard waste and green waste removal specialists. We haul tree trimmings, palm fronds, brush, and organic yard waste — fast, eco-friendly disposal throughout Chandler.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="/#contact" class="inline-flex items-center justify-center bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl transition text-lg">Get a Free Estimate</a>
          <a href="tel:+16026325794" class="inline-flex items-center justify-center border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-xl transition text-lg">(602) 632-5794</a>
        </div>
      </div>
    </div>
  </section>
  <main>
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Yard Waste We Haul in Chandler</h2>
        <div class="grid sm:grid-cols-2 gap-3 max-w-4xl mx-auto">
          {['Tree branches & limbs', 'Palm fronds & palm debris', 'Shrub & hedge trimmings', 'Grass clippings & sod', 'Cactus & desert plant debris', 'Stump & root removal waste', 'Brush & undergrowth', 'Leaves & organic mulch', 'Soil & dirt (small quantities)', 'Post-landscaping cleanup debris'].map(item => (
            <div class="flex items-center gap-3 bg-gray-50 rounded-xl px-4 py-3"><span class="text-brand-500 font-bold text-lg">&#10003;</span><span class="text-navy-700 text-sm font-medium">{item}</span></div>
          ))}
        </div>
      </div>
    </section>
    <section class="py-16 bg-gray-50">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">When to Schedule Yard Waste Hauling in Chandler</h2>
        <ul class="space-y-4 text-navy-600">
          <li class="flex gap-3"><span class="text-brand-500 font-bold mt-1">&#10003;</span><span>After a Chandler landscaping project leaves large piles of trimmings or organic waste on your property.</span></li>
          <li class="flex gap-3"><span class="text-brand-500 font-bold mt-1">&#10003;</span><span>Post-monsoon cleanup when wind has scattered debris across your Chandler yard or commercial landscape.</span></li>
          <li class="flex gap-3"><span class="text-brand-500 font-bold mt-1">&#10003;</span><span>Seasonal cleanups when palm fronds or desert vegetation need to be cleared from your Chandler property.</span></li>
          <li class="flex gap-3"><span class="text-brand-500 font-bold mt-1">&#10003;</span><span>When you have removed shrubs or desert landscaping and have large volumes of organic material to dispose of.</span></li>
          <li class="flex gap-3"><span class="text-brand-500 font-bold mt-1">&#10003;</span><span>Your Chandler HOA needs reliable ongoing green waste hauling for common areas.</span></li>
        </ul>
      </div>
    </section>
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-12 text-center">Our Chandler Yard Waste Hauling Process</h2>
        <div class="space-y-8">
          {[{ step: '1', title: 'Call or Request Online', desc: 'Contact Fill & Haul at (602) 632-5794 or submit an estimate request. Same-day service throughout Chandler.' }, { step: '2', title: 'Upfront Quote', desc: 'We assess your yard waste volume and give a firm flat-rate price on-site. No hidden fees.' }, { step: '3', title: 'Eco-Friendly Haul-Away', desc: 'We load all yard waste and deliver it to composting or green waste facilities. We keep Chandler clean.' }].map(p => (
            <div class="flex gap-6 items-start">
              <div class="flex-shrink-0 w-12 h-12 bg-brand-500 text-white rounded-full flex items-center justify-center font-heading font-extrabold text-xl">{p.step}</div>
              <div><h3 class="font-heading font-bold text-xl text-navy-900 mb-2">{p.title}</h3><p class="text-navy-500">{p.desc}</p></div>
            </div>
          ))}
        </div>
      </div>
    </section>
    <section class="py-16 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Chandler Yard Waste FAQ</h2>
        <div class="space-y-4">
          {faqs.map(f => (
            <details class="group bg-white rounded-2xl border border-navy-100 overflow-hidden">
              <summary class="list-none flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-navy-900">{f.q}<svg class="w-5 h-5 text-brand-500 flex-shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg></summary>
              <div class="px-6 pb-4 text-navy-500 text-sm">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">More Chandler Hauling Services</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {[{ title: 'Chandler Hauling Services', href: '/chandler-hauling-services/' }, { title: 'Junk Removal', href: '/chandler/junk-removal/' }, { title: 'Debris Removal', href: '/chandler/debris-removal/' }, { title: 'Construction Debris Removal', href: '/chandler/construction-debris-removal/' }].map(s => (
            <a href={s.href} class="bg-gray-50 border border-navy-100 rounded-xl p-4 text-center hover:border-brand-300 hover:shadow-sm transition"><span class="font-semibold text-navy-800 text-sm">{s.title}</span></a>
          ))}
        </div>
      </div>
    </section>
    <section class="py-16 bg-brand-500">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Schedule Yard Waste Hauling in Chandler Today</h2>
        <p class="text-white/90 text-lg mb-8">Eco-friendly yard waste removal throughout Chandler. Same-day service available.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
          <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
