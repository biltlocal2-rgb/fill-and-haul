---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Chandler, AZ Hauling & Junk Removal Services | Fill & Haul';
const pageDescription = 'Professional junk removal and hauling services in Chandler, AZ. Fill & Haul offers fast, affordable same-day service for furniture, debris, yard waste, and more. Free estimates. Call (602) 632-5794.';

const faqs = [
  { q: 'Do you offer same-day junk removal in Chandler?', a: 'Yes! Fill & Haul serves all of Chandler including 85224, 85225, 85226, 85248, 85249 and surrounding zip codes. Same-day and next-day appointments available.' },
  { q: 'How much does junk removal cost in Chandler?', a: 'Most Chandler jobs range from $150 for small loads to $600+ for full property cleanouts. We provide free on-site estimates before any work begins.' },
  { q: 'What neighborhoods in Chandler do you serve?', a: 'We serve all of Chandler including Ocotillo, Fulton Ranch, Sun Lakes, Chandler Heights, Alma School Corridor, Pecos Ranch, and all surrounding communities.' },
  { q: 'Can you haul away construction debris in Chandler?', a: 'Absolutely. We handle drywall, lumber, concrete, roofing materials, and all types of construction and renovation debris from Chandler job sites.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Hauling & Junk Removal in Chandler, AZ",
      "provider": { "@type": "LocalBusiness", "name": "Fill & Haul", "telephone": "+16026325794" },
      "areaServed": { "@type": "City", "name": "Chandler, Arizona" },
      "description": pageDescription,
      "url": "https://fillandhaul.com/chandler/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Chandler Hauling Services", "item": "https://fillandhaul.com/chandler/" }
      ]
    }
  ]
};

const services = [
  { title: 'Junk Removal', href: '/chandler/junk-removal/', desc: 'Full-service junk pickup and disposal throughout Chandler.' },
  { title: 'Debris Removal', href: '/chandler/debris-removal/', desc: 'Fast debris haul-away for homes and job sites in Chandler.' },
  { title: 'Yard Waste Hauling', href: '/chandler/yard-waste-hauling/', desc: 'Tree branches, grass clippings, and landscaping debris removed.' },
  { title: 'Construction Debris Removal', href: '/chandler/construction-debris-removal/', desc: 'Drywall, lumber, concrete, roofing, and renovation waste hauled away.' },
  { title: 'Furniture & Appliance Removal', href: '/chandler/furniture-appliance-removal/', desc: 'Old sofas, beds, refrigerators, washers, and more removed quickly.' },
];
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20" aria-label="Breadcrumb">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-navy-500">
        <li><a href="/" class="hover:text-brand-500 transition">Home</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-navy-800 font-medium">Chandler</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative py-20 lg:py-28 text-white" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-brand-400 font-semibold text-sm uppercase tracking-widest mb-4">Chandler, AZ</p>
      <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold mb-6 leading-tight">
        Hauling & Junk Removal<br/>
        <span class="text-brand-400">in Chandler, AZ</span>
      </h1>
      <p class="text-white/80 text-xl mb-10 max-w-2xl mx-auto">
        Fast, affordable junk removal and hauling throughout Chandler. Same-day service available in Ocotillo, Sun Lakes, Fulton Ranch, and all surrounding neighborhoods.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4 text-center">Chandler Hauling Services</h2>
      <p class="text-navy-600 text-center mb-10 max-w-2xl mx-auto">We offer a full range of hauling and removal services throughout Chandler. Click a service below to learn more.</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <a href={s.href} class="bg-gray-50 border border-navy-100 rounded-2xl p-6 hover:border-brand-300 hover:shadow-md transition group">
            <h3 class="font-heading text-lg font-bold text-navy-900 mb-2 group-hover:text-brand-600 transition">{s.title}</h3>
            <p class="text-navy-600 text-sm">{s.desc}</p>
            <span class="mt-4 inline-flex items-center text-brand-500 font-semibold text-sm">Learn more &rarr;</span>
          </a>
        ))}
        <a href="/chandler-hauling-services/" class="bg-brand-500 rounded-2xl p-6 hover:bg-brand-600 transition group">
          <h3 class="font-heading text-lg font-bold text-white mb-2">All Chandler Services</h3>
          <p class="text-white/80 text-sm">View our complete Chandler hauling services guide with pricing and service area details.</p>
          <span class="mt-4 inline-flex items-center text-white font-semibold text-sm">View all &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Why Fill & Haul -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4 text-center">Why Chandler Chooses Fill & Haul</h2>
      <div class="grid sm:grid-cols-2 gap-4 mt-8">
        {[
          "Same-day and next-day service throughout Chandler",
          "Transparent flat-rate pricing — no surprise fees",
          "Licensed and insured professionals",
          "Eco-friendly disposal and recycling",
          "Heavy-load capability for any project size",
          "Serving Ocotillo, Sun Lakes, Fulton Ranch & more"
        ].map(item => (
          <div class="flex items-center gap-3 bg-white rounded-xl px-5 py-4 border border-gray-100">
            <svg class="w-5 h-5 text-brand-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
            <span class="text-navy-800 font-medium">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Chandler Junk Removal FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <details class="group bg-white rounded-2xl border border-navy-100 overflow-hidden">
            <summary class="list-none flex items-center justify-between px-6 py-4 cursor-pointer font-semibold text-navy-900">{f.q}<svg class="w-5 h-5 text-brand-500 flex-shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg></summary>
            <div class="px-6 pb-4 text-navy-500 text-sm">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Nearby Cities -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">Also Serving the East Valley</h2>
      <p class="text-navy-600 mb-6">Fill & Haul serves Chandler and all nearby communities throughout the East Valley.</p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/mesa-hauling-services/" class="bg-white border border-navy-100 rounded-xl px-6 py-3 text-navy-800 font-semibold hover:border-brand-300 hover:shadow-sm transition">Mesa</a>
        <a href="/gilbert-hauling-services/" class="bg-white border border-navy-100 rounded-xl px-6 py-3 text-navy-800 font-semibold hover:border-brand-300 hover:shadow-sm transition">Gilbert</a>
        <a href="/tempe-hauling-services/" class="bg-white border border-navy-100 rounded-xl px-6 py-3 text-navy-800 font-semibold hover:border-brand-300 hover:shadow-sm transition">Tempe</a>
        <a href="/phoenix-hauling-services/" class="bg-white border border-navy-100 rounded-xl px-6 py-3 text-navy-800 font-semibold hover:border-brand-300 hover:shadow-sm transition">Phoenix</a>
        <a href="/scottsdale-hauling-services/" class="bg-white border border-navy-100 rounded-xl px-6 py-3 text-navy-800 font-semibold hover:border-brand-300 hover:shadow-sm transition">Scottsdale</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Ready to Schedule Chandler Junk Removal?</h2>
      <p class="text-white/90 text-lg mb-8">Same-day service available. Licensed, insured, and eco-friendly disposal throughout Chandler, AZ.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</Layout>
