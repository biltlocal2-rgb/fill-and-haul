---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Junk Removal Gilbert AZ | Same-Day Hauling | Fill & Haul';
const pageDescription = 'Professional junk removal and hauling in Gilbert, AZ. Fill & Haul serves all of Gilbert with fast, affordable same-day service. Furniture, appliances, yard waste, and more. Free estimates.';

const faqs = [
  { q: 'Do you offer junk removal in Gilbert, AZ?', a: 'Yes! Fill & Haul serves all of Gilbert including 85233, 85234, 85295, 85296, 85297, 85298, and 85299 zip codes. Same-day and next-day appointments available.' },
  { q: 'How much does junk removal cost in Gilbert?', a: 'Gilbert jobs typically range from $150 for small loads to $600+ for full property cleanouts. Free on-site estimates with no obligation.' },
  { q: 'What areas of Gilbert do you serve?', a: 'We serve all of Gilbert including the Heritage District, Val Vista Lakes, Power Ranch, Agritopia, and all surrounding communities near Chandler and Mesa.' },
  { q: 'Do you haul yard waste in Gilbert?', a: 'Yes! We remove tree trimmings, branches, landscaping debris, dirt, rocks, and all types of yard waste from Gilbert properties.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Junk Removal in Gilbert, AZ",
      "provider": { "@type": "LocalBusiness", "name": "Fill & Haul", "telephone": "+16026325794" },
      "areaServed": { "@type": "City", "name": "Gilbert, Arizona" },
      "description": pageDescription,
      "url": "https://fillandhaul.com/gilbert/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question", "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Gilbert Junk Removal", "item": "https://fillandhaul.com/gilbert/" }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />
  <nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-brand-600 transition">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-navy-700 font-medium">Gilbert Junk Removal</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-navy-900 text-white py-20" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 text-center lg:text-left">
          Junk Removal in <span class="text-brand-400">Gilbert, AZ</span>
        </h1>
        <p class="text-xl text-navy-200 mb-8 text-center lg:text-left">Trusted junk removal for Gilbert families and businesses. We haul furniture, appliances, yard waste, construction debris, and more with same-day service available across all of Gilbert.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="/#contact" class="inline-flex items-center justify-center bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl transition text-lg">Get a Free Estimate</a>
          <a href="tel:+16026325794" class="inline-flex items-center justify-center border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-xl transition text-lg">(602) 632-5794</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-navy-900 mb-4">Gilbert's Top-Rated Junk Removal Service</h2>
        <p class="text-navy-500 text-lg max-w-2xl mx-auto">Fill & Haul is Gilbert's go-to for fast, affordable, and eco-conscious junk removal for families and businesses.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '&#128336;', title: 'Same-Day Available', desc: 'Need it gone today? Call early and we can often serve Gilbert same-day.' },
          { icon: '&#128176;', title: 'Upfront Pricing', desc: 'We quote before we load. No surprises on your Gilbert junk removal bill.' },
          { icon: '&#9989;', title: 'Licensed & Insured', desc: 'Fully covered for residential and commercial work across Gilbert.' },
          { icon: '&#127807;', title: 'Eco-Friendly', desc: 'We donate, recycle, and responsibly dispose to protect the East Valley.' },
        ].map(item => (
          <div class="bg-gray-50 rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3" set:html={item.icon}></div>
            <h3 class="font-heading font-bold text-lg text-navy-900 mb-2">{item.title}</h3>
            <p class="text-navy-500 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">What We Haul in Gilbert</h2>
        <p class="text-navy-500 text-lg">From single items to full property cleanouts across Gilbert.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Furniture Removal', desc: 'Couches, beds, tables, wardrobes - we remove any unwanted furniture from Gilbert homes.' },
          { title: 'Appliance Hauling', desc: 'Old fridges, washers, dryers, and ovens safely removed from Gilbert properties.' },
          { title: 'Yard Waste Hauling', desc: 'Tree trimmings, landscaping debris, dirt, and rocks cleared from Gilbert yards.' },
          { title: 'Construction Debris', desc: 'Renovation and job site cleanup for Gilbert contractors and homeowners.' },
          { title: 'Property Cleanouts', desc: 'Estate sales, rental turnovers, and foreclosure cleanouts throughout Gilbert.' },
          { title: 'Garage Cleanouts', desc: 'Fully clear out your Gilbert garage - we sort, haul, and clean up after.' },
        ].map(s => (
          <div class="bg-white border border-navy-100 rounded-2xl p-6 hover:shadow-md transition">
            <h3 class="font-heading font-bold text-lg text-navy-900 mb-2">{s.title}</h3>
            <p class="text-navy-500 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">Serving All of Gilbert, AZ</h2>
        <p class="text-navy-500 text-lg mb-6">We cover all Gilbert zip codes: 85233, 85234, 85295, 85296, 85297, 85298, and 85299 - plus nearby Queen Creek and San Tan Valley.</p>
        <p class="text-navy-500">Also serving: <a href="/chandler/" class="text-brand-600 hover:underline">Chandler</a>, <a href="/mesa/" class="text-brand-600 hover:underline">Mesa</a>, <a href="/tempe/" class="text-brand-600 hover:underline">Tempe</a>, and <a href="/scottsdale/" class="text-brand-600 hover:underline">Scottsdale</a>.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Gilbert Junk Removal FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="bg-white rounded-2xl p-6 border border-navy-100">
            <h3 class="font-semibold text-navy-900 mb-2">{f.q}</h3>
            <p class="text-navy-500 text-sm">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Schedule Junk Removal in Gilbert Today</h2>
      <p class="text-white/90 text-lg mb-8">Same-day service available. Proudly serving Gilbert and the entire Southeast Valley.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
