---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const pageTitle = 'Junk Removal Scottsdale AZ | Same-Day Hauling | Fill & Haul';
const pageDescription = 'Professional junk removal and hauling in Scottsdale, AZ. Fill & Haul serves all of Scottsdale with discreet, fast service for homes and businesses. Furniture, appliances, estate cleanouts, and more. Free estimates.';

const faqs = [
  { q: 'Do you offer junk removal in Scottsdale, AZ?', a: 'Yes! Fill & Haul serves all of Scottsdale including North Scottsdale, Old Town, South Scottsdale, and zip codes 85250-85262, 85266, and 85268. Same-day service available.' },
  { q: 'Do you handle estate cleanouts in Scottsdale?', a: 'Absolutely. We specialize in full estate cleanouts for Scottsdale homeowners, realtors, and property managers. We remove everything quickly and professionally.' },
  { q: 'How much does junk removal cost in Scottsdale?', a: 'Scottsdale pricing typically ranges from $150 for small loads to $700+ for large estate or commercial cleanouts. Free on-site estimates with no obligation.' },
  { q: 'Do you serve North Scottsdale?', a: 'Yes, we serve all of Scottsdale including North Scottsdale, McDowell Mountain, Troon, DC Ranch, and all surrounding areas including Paradise Valley.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": "Junk Removal in Scottsdale, AZ",
      "provider": { "@type": "LocalBusiness", "name": "Fill & Haul", "telephone": "+16026325794" },
      "areaServed": { "@type": "City", "name": "Scottsdale, Arizona" },
      "description": pageDescription,
      "url": "https://fillandhaul.com/scottsdale/"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question", "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
        { "@type": "ListItem", "position": 2, "name": "Scottsdale Junk Removal", "item": "https://fillandhaul.com/scottsdale/" }
      ]
    }
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />
  <nav aria-label="Breadcrumb" class="bg-gray-50 border-b border-gray-200 mt-16 lg:mt-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center space-x-2 text-sm text-gray-500">
        <li><a href="/" class="hover:text-brand-600 transition">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="text-navy-700 font-medium">Scottsdale Junk Removal</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-navy-900 text-white py-20" style="background: linear-gradient(135deg, #102a43 0%, #243b53 60%, #334e68 100%)">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 text-center lg:text-left">
          Junk Removal in <span class="text-brand-400">Scottsdale, AZ</span>
        </h1>
        <p class="text-xl text-navy-200 mb-8 text-center lg:text-left">Discreet, professional junk removal for Scottsdale homes and businesses. We handle estate cleanouts, furniture removal, appliance hauling, and construction debris with same-day service available.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a href="/#contact" class="inline-flex items-center justify-center bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl transition text-lg">Get a Free Estimate</a>
          <a href="tel:+16026325794" class="inline-flex items-center justify-center border border-white/30 hover:border-white/60 text-white font-medium px-8 py-4 rounded-xl transition text-lg">(602) 632-5794</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-navy-900 mb-4">Scottsdale's Professional Junk Removal Team</h2>
        <p class="text-navy-500 text-lg max-w-2xl mx-auto">Fill & Haul brings reliable, professional junk removal to Scottsdale's homes, estates, and commercial properties.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          { icon: '&#128336;', title: 'Same-Day Service', desc: 'Fast response throughout Scottsdale - often same-day if you call before noon.' },
          { icon: '&#128176;', title: 'Transparent Pricing', desc: 'Firm upfront quotes before any work begins. No hidden costs.' },
          { icon: '&#9989;', title: 'Licensed & Insured', desc: 'Fully licensed and insured for Scottsdale residential and commercial work.' },
          { icon: '&#127807;', title: 'Responsible Disposal', desc: 'We donate and recycle whenever possible - good for the Valley and the planet.' },
        ].map(item => (
          <div class="bg-gray-50 rounded-2xl p-6 text-center">
            <div class="text-4xl mb-3" set:html={item.icon}></div>
            <h3 class="font-heading font-bold text-lg text-navy-900 mb-2">{item.title}</h3>
            <p class="text-navy-500 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">What We Haul in Scottsdale</h2>
        <p class="text-navy-500 text-lg">Full-service junk removal for Scottsdale's residential and commercial properties.</p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Estate Cleanouts', desc: 'Full estate cleanouts for Scottsdale realtors, families, and property managers - fast and discreet.' },
          { title: 'Furniture Removal', desc: 'Luxury or standard - we remove any furniture from Scottsdale homes and offices.' },
          { title: 'Appliance Hauling', desc: 'Old appliances removed safely from Scottsdale properties with eco-friendly disposal.' },
          { title: 'Construction Debris', desc: 'Renovation and remodel debris cleanup for Scottsdale contractors and homeowners.' },
          { title: 'Property Cleanouts', desc: 'Foreclosure, rental turnover, and pre-sale cleanouts throughout Scottsdale.' },
          { title: 'Office Cleanouts', desc: 'Commercial junk removal for Scottsdale businesses, offices, and retail spaces.' },
        ].map(s => (
          <div class="bg-white border border-navy-100 rounded-2xl p-6 hover:shadow-md transition">
            <h3 class="font-heading font-bold text-lg text-navy-900 mb-2">{s.title}</h3>
            <p class="text-navy-500 text-sm">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service Area -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-4">Serving All of Scottsdale, AZ</h2>
        <p class="text-navy-500 text-lg mb-6">We cover all Scottsdale zip codes: 85250, 85251, 85252, 85253, 85254, 85255, 85257, 85258, 85259, 85260, 85261, 85262, 85266, and 85268 including North Scottsdale and Old Town.</p>
        <p class="text-navy-500">Also serving: <a href="/phoenix/" class="text-brand-600 hover:underline">Phoenix</a>, <a href="/tempe/" class="text-brand-600 hover:underline">Tempe</a>, <a href="/mesa/" class="text-brand-600 hover:underline">Mesa</a>, and <a href="/chandler/" class="text-brand-600 hover:underline">Chandler</a>.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-heading text-3xl font-extrabold text-navy-900 mb-8 text-center">Scottsdale Junk Removal FAQ</h2>
      <div class="space-y-4">
        {faqs.map(f => (
          <div class="bg-white rounded-2xl p-6 border border-navy-100">
            <h3 class="font-semibold text-navy-900 mb-2">{f.q}</h3>
            <p class="text-navy-500 text-sm">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-brand-500">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading text-3xl font-extrabold text-white mb-4">Book Junk Removal in Scottsdale Today</h2>
      <p class="text-white/90 text-lg mb-8">Professional, discreet service throughout Scottsdale and the Greater Phoenix area.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:+16026325794" class="inline-flex items-center justify-center bg-white text-brand-600 font-bold px-8 py-4 rounded-xl hover:bg-gray-100 transition text-lg">(602) 632-5794</a>
        <a href="/#contact" class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-xl hover:bg-white/10 transition text-lg">Get a Free Estimate</a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
