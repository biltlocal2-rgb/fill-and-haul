---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';

const pageTitle = 'Yard Waste Hauling Tempe AZ | Lawn & Garden Debris Removal | Fill & Haul';
const pageDescription = 'Professional yard waste hauling in Tempe, AZ. Fill & Haul removes grass clippings, branches, leaves, tree limbs, and landscaping debris fast. Same-day service available. Call (602) 632-5794.';

const faqs = [
  { q: 'What yard waste do you haul in Tempe?', a: 'We haul grass clippings, leaves, branches, tree limbs, stumps (small to medium), bushes, shrubs, sod, dirt, rocks, mulch, and all other landscaping debris from residential and commercial properties in Tempe.' },
  { q: 'Do you haul yard waste after a storm?', a: 'Yes. Storm cleanup is one of our most common requests. We respond quickly to haul away fallen branches, tree limbs, uprooted shrubs, and scattered debris after monsoon or wind events in Tempe and the surrounding Valley.' },
  { q: 'Can you haul away a full truckload of yard debris?', a: 'Absolutely. We handle any size job from a single pickup load to multiple truckloads. Our pricing is based on volume so you only pay for what we haul away.' },
  { q: 'Is yard waste recycled or landfilled?', a: 'Whenever possible we divert yard waste from landfills. Organic material like grass, leaves, and branches is taken to composting or green-waste facilities. We follow Tempe and Maricopa County green disposal guidelines.' },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Service", "name": "Yard Waste Hauling in Tempe, AZ", "provider": { "@type": "LocalBusiness", "name": "Fill & Haul", "telephone": "+16026325794" }, "areaServed": { "@type": "City", "name": "Tempe" }, "serviceType": "Yard Waste Hauling", "url": "https://fillandhaul.com/tempe/yard-waste-hauling/" },
    { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
    { "@type": "BreadcrumbList", "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fillandhaul.com/" },
      { "@type": "ListItem", "position": 2, "name": "Tempe Hauling Services", "item": "https://fillandhaul.com/tempe-hauling-services/" },
      { "@type": "ListItem", "position": 3, "name": "Yard Waste Hauling", "item": "https://fillandhaul.com/tempe/yard-waste-hauling/" }
    ]}
  ]
};
---

<Layout title={pageTitle} description={pageDescription}>
  <Navbar />

  <nav aria-label="Breadcrumb" class="bg-gray-100 border-b border-gray-200 mt-16 lg:mt-20">
    <div class="max-w-6xl mx-auto px-4 py-3">
      <ol class="flex items-center gap-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-brand-500">Home</a></li>
        <li class="text-gray-400">/</li>
        <li><a href="/tempe-hauling-services/" class="hover:text-brand-500">Tempe Hauling Services</a></li>
        <li class="text-gray-400">/</li>
        <li class="text-gray-900 font-medium">Yard Waste Hauling</li>
      </ol>
    </div>
  </nav>

  <section class="bg-slate-800 text-white py-20 px-4">
    <div class="max-w-5xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight">
        Yard Waste Hauling in <span class="text-brand-500">Tempe, AZ</span>
      </h1>
      <p class="text-lg md:text-xl text-slate-300 mb-8 max-w-2xl mx-auto">
        Grass clippings, branches, leaves, sod — we haul it all. Fast same-day service for homeowners, landscapers, and property managers throughout Tempe and the East Valley.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:6026325794" class="bg-brand-500 hover:bg-brand-600 text-white font-bold py-4 px-8 rounded-lg text-lg transition-colors">Call (602) 632-5794</a>
        <a href="/#estimate" class="border-2 border-white text-white hover:bg-white hover:text-slate-800 font-bold py-4 px-8 rounded-lg text-lg transition-colors">Get Free Estimate</a>
      </div>
    </div>
  </section>

  <main class="max-w-5xl mx-auto px-4 py-16">

    <section class="mb-16">
      <h2 class="text-3xl font-bold text-slate-800 mb-6">Tempe's Trusted Yard Waste Hauling Crew</h2>
      <p class="text-lg text-slate-600 mb-4">After a weekend of landscaping, storm cleanup, or a big yard renovation, you are left with piles of debris that will not fit in your city trash bin. Fill & Haul makes it easy — we show up, load everything, and haul it away so you can enjoy your yard again.</p>
      <p class="text-lg text-slate-600 mb-4">Serving Tempe homeowners, HOAs, landscaping contractors, and property managers, our crew is equipped to handle any volume of yard waste. We bring the truck, do the loading, and handle responsible disposal at certified green-waste facilities whenever possible.</p>
      <p class="text-lg text-slate-600">Whether it is a single pile of branches or a full yard clearing project, Fill & Haul provides fast, transparent pricing with no hidden fees. Most yard waste jobs in Tempe are completed the same day you call.</p>
    </section>

    <section class="mb-16 bg-gray-50 rounded-2xl p-8">
      <h2 class="text-3xl font-bold text-slate-800 mb-6">Yard Waste We Haul in Tempe</h2>
      <p class="text-slate-600 mb-6">We remove all types of organic and landscaping debris from Tempe properties:</p>
      <ul class="grid grid-cols-1 md:grid-cols-2 gap-3">
        {['Grass clippings & lawn trimmings', 'Tree branches & large limbs', 'Leaves & leaf piles', 'Shrubs, bushes & hedges', 'Tree stumps (small to medium)', 'Palm fronds & cactus debris', 'Sod & turf removal', 'Garden soil & dirt', 'Rocks & gravel', 'Mulch & wood chips', 'Weeds & invasive plants', 'Storm debris & fallen trees'].map(item => (
          <li class="flex items-center gap-3 text-slate-700"><span class="text-brand-500 font-bold text-lg">✓</span>{item}</li>
        ))}
      </ul>
    </section>

    <section class="mb-16">
      <h2 class="text-3xl font-bold text-slate-800 mb-8">Why Tempe Homeowners & Landscapers Choose Fill & Haul</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { icon: '🌿', title: 'Eco-Friendly Disposal', desc: 'We divert organic yard waste to certified composting and green-waste facilities — keeping it out of Tempe landfills whenever possible.' },
          { icon: '⚡', title: 'Same-Day Availability', desc: 'Most yard waste pickups in Tempe are available the same day you call. Schedule morning or afternoon windows to fit your project.' },
          { icon: '💪', title: 'We Do All the Loading', desc: 'No raking or bagging required on your part. Our crew loads everything from your yard directly into our truck.' },
          { icon: '📏', title: 'Any Size Job', desc: 'From a single wheelbarrow of clippings to a full lot clearing, our volume-based pricing ensures you pay only for what you use.' },
          { icon: '🏡', title: 'Residential & HOA Friendly', desc: 'We service individual homeowners, HOA-managed communities, rental properties, and landscaping contractor clients throughout Tempe.' },
          { icon: '💰', title: 'Upfront Pricing', desc: 'We quote your job before we start. No surprise fees — ever. Transparent pricing is the Fill & Haul standard.' },
        ].map(item => (
          <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
            <div class="text-4xl mb-4">{item.icon}</div>
            <h3 class="text-xl font-bold text-slate-800 mb-2">{item.title}</h3>
            <p class="text-slate-600 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-16 bg-orange-50 border border-orange-200 rounded-2xl p-8">
      <h2 class="text-3xl font-bold text-slate-800 mb-6">Yard Waste Hauling for Arizona's Unique Climate</h2>
      <p class="text-slate-700 mb-4">Arizona's landscape creates year-round yard waste challenges that differ from other parts of the country. Tempe homeowners deal with palm frond shedding, monsoon storm debris, mesquite and palo verde tree trimmings, cactus removal, and heavy gravel or rock landscaping projects.</p>
      <p class="text-slate-700 mb-4">Our crew is experienced with all of it. We know how heavy and sharp palm fronds can be, how messy cactus removal gets, and how quickly storm debris piles up after a monsoon. Fill & Haul is equipped with the right tools and protective gear to handle Arizona-specific yard waste safely and efficiently.</p>
      <p class="text-slate-700">We also understand local disposal rules — Tempe has specific guidelines around organic waste, and we make sure your yard debris goes to appropriate facilities.</p>
    </section>

    <section class="mb-16">
      <h2 class="text-3xl font-bold text-slate-800 mb-6">Signs It's Time to Call for Yard Waste Pickup</h2>
      <div class="space-y-4">
        {[
          { title: 'After a Storm or Monsoon', desc: 'Monsoon season leaves Tempe yards covered in branches, leaves, and debris. We respond fast for storm cleanup to get your property safe and tidy.' },
          { title: 'Post-Landscaping Project', desc: 'Finished a big landscaping renovation? We clear out the leftover sod, old plants, gravel, and garden waste so you can enjoy the results.' },
          { title: 'Spring & Fall Yard Cleanup', desc: 'Seasonal cleanups generate more debris than city bins can hold. Schedule a Fill & Haul pickup to clear it all in one visit.' },
          { title: 'Tree or Shrub Removal', desc: 'When a tree service removes a tree or large shrub, they often leave the debris behind. We haul it all — logs, branches, stump grindings, and leaves.' },
          { title: 'Rental Property Turnover', desc: 'Overgrown or neglected yards at rental properties need fast turnaround. We clear and haul yard waste quickly so you can get your property back on the market.' },
        ].map(item => (
          <div class="flex gap-4 p-5 bg-white border border-gray-200 rounded-xl shadow-sm">
            <span class="text-brand-500 text-2xl mt-1">→</span>
            <div>
              <h3 class="font-bold text-slate-800 mb-1">{item.title}</h3>
              <p class="text-slate-600 text-sm">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-16 bg-slate-800 text-white rounded-2xl p-8">
      <h2 class="text-3xl font-bold mb-8 text-center">How Yard Waste Hauling Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {[
          { step: '1', title: 'Call or Request Online', desc: 'Reach out by phone or submit a request. Tell us about the type and volume of yard waste you need removed.' },
          { step: '2', title: 'Same-Day Scheduling', desc: 'We schedule your pickup — often same-day — and give you an arrival window. No all-day waiting around.' },
          { step: '3', title: 'We Load Everything', desc: 'Our crew does all the heavy lifting. We load your yard waste directly into the truck — you do not lift a thing.' },
          { step: '4', title: 'Eco-Friendly Disposal', desc: 'We transport your yard waste to certified green-waste or composting facilities, keeping as much out of landfills as possible.' },
        ].map(item => (
          <div class="text-center">
            <div class="w-12 h-12 rounded-full bg-brand-500 text-white font-bold text-xl flex items-center justify-center mx-auto mb-4">{item.step}</div>
            <h3 class="font-bold text-lg mb-2">{item.title}</h3>
            <p class="text-slate-300 text-sm">{item.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-3xl font-bold text-slate-800 mb-8">Frequently Asked Questions — Yard Waste Hauling Tempe</h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="border border-gray-200 rounded-xl overflow-hidden group">
            <summary class="flex items-center justify-between p-5 cursor-pointer bg-white hover:bg-gray-50 font-semibold text-slate-800 list-none">
              {faq.q}
              <span class="text-brand-500 text-xl transition-transform group-open:rotate-45">+</span>
            </summary>
            <div class="p-5 pt-0 bg-white text-slate-600">
              <p class="pt-4 border-t border-gray-100">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </section>

    <section class="mb-16">
      <h2 class="text-3xl font-bold text-slate-800 mb-6">Related Hauling Services in Tempe</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { title: 'Junk Removal', desc: 'Household junk, furniture, appliances, and general clutter removed fast.', href: '/tempe/junk-removal/' },
          { title: 'Debris Removal', desc: 'Construction, renovation, and demolition debris hauled away.', href: '/tempe/debris-removal/' },
          { title: 'Construction Debris Removal', desc: 'Job site cleanups for contractors and builders throughout Tempe.', href: '/tempe/construction-debris-removal/' },
          { title: 'Furniture & Appliance Removal', desc: 'Old couches, refrigerators, mattresses, and more removed and disposed.', href: '/tempe/furniture-appliance-removal/' },
          { title: 'All Tempe Hauling Services', desc: 'See our full range of hauling and removal services for Tempe.', href: '/tempe-hauling-services/' },
        ].map(link => (
          <a href={link.href} class="block p-5 bg-white border border-gray-200 rounded-xl shadow-sm hover:border-brand-500 hover:shadow-md transition-all">
            <h3 class="font-bold text-slate-800 mb-1">{link.title}</h3>
            <p class="text-sm text-slate-500">{link.desc}</p>
          </a>
        ))}
      </div>
    </section>

  </main>

  <section class="bg-brand-500 text-white py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold mb-4">Ready to Clear Your Yard?</h2>
      <p class="text-lg mb-8 text-orange-100">Fast, affordable yard waste hauling in Tempe. Same-day service available — call now or request a free estimate online.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:6026325794" class="bg-white text-brand-500 hover:bg-orange-50 font-bold py-4 px-8 rounded-lg text-lg transition-colors">Call (602) 632-5794</a>
        <a href="/#estimate" class="border-2 border-white text-white hover:bg-orange-600 font-bold py-4 px-8 rounded-lg text-lg transition-colors">Get Free Estimate</a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <Footer />
</Layout>
