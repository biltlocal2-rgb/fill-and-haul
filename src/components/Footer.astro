---
const year = new Date().getFullYear();
---

<footer class="bg-navy-900 text-navy-300 py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-3 gap-8 mb-8">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center space-x-2 mb-4">
          <!-- Hauling trailer icon in brand orange, no background box -->
          <svg class="w-9 h-9 text-brand-500" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
            <!-- Trailer body -->
            <rect x="2" y="7" width="15" height="8" rx="1.5" />
            <!-- Hitch bar -->
            <line x1="17" y1="11" x2="22" y2="11" />
            <!-- Hitch ball -->
            <circle cx="22" cy="11" r="1" />
            <!-- Left wheel -->
            <circle cx="6" cy="17" r="2" />
            <!-- Right wheel -->
            <circle cx="13" cy="17" r="2" />
          </svg>
          <span class="font-heading font-extrabold text-lg text-white">Fill &amp; Haul</span>
        </a>
        <p class="text-sm leading-relaxed">
          Professional junk removal and hauling services serving Tempe and the entire Maricopa County area.
        </p>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-semibold text-white mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/tempe-hauling-services/" class="hover:text-white transition">Services</a></li>
          <li><a href="/tempe/junk-removal/" class="hover:text-white transition">Junk Removal</a></li>
          <li><a href="/tempe/debris-removal/" class="hover:text-white transition">Debris Removal</a></li>
          <li><a href="/#contact" class="hover:text-white transition">Get Estimate</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-semibold text-white mb-4">Contact</h4>
        <ul class="space-y-2 text-sm">
          <li>Phoenix, AZ &mdash; Maricopa County</li>
          <li><a href="tel:+16026325794" class="hover:text-white transition">(602) 632-5794</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-navy-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm">&copy; {year} Fill &amp; Haul. All rights reserved.</p>
      <p class="text-sm text-navy-500">Proudly serving the Phoenix Metro Area</p>
    </div>
  </div>
</footer>
