---
// Hero section with headline + quick quote form
---

<section class="hero-gradient hero-pattern relative overflow-hidden min-h-[90vh] flex items-center" style="background: linear-gradient(135deg, #102a43 0%, #243b53 50%, #334e68 100%)">
  <!-- Decorative blurs -->
  <div class="absolute top-20 right-10 w-72 h-72 bg-brand-500/10 rounded-full blur-3xl"></div>
  <div class="absolute bottom-10 left-10 w-96 h-96 bg-brand-500/5 rounded-full blur-3xl"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left Content -->
      <div>
        <h1 class="font-heading text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Junk Gone.<br />
          <span class="text-brand-400">Space Reclaimed.</span>
        </h1>

        <p class="text-lg text-navy-200 mb-8 max-w-lg leading-relaxed">
          Fast, reliable junk removal and hauling for homeowners, realtors, and property managers across the Valley.
          We handle the heavy lifting so you don't have to.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 mb-10">
          <a href="#contact"
            class="cta-pulse inline-flex items-center justify-center bg-brand-500 hover:bg-brand-600 text-white font-semibold px-8 py-4 rounded-xl transition text-lg">
            Get a Free Estimate
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="#services"
            class="inline-flex items-center justify-center border border-white/20 hover:border-white/40 text-white font-medium px-8 py-4 rounded-xl transition text-lg">
            Our Services
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-6 text-sm text-navy-300">
          {['Licensed & Insured', 'Same-Day Available', 'Free Estimates'].map(badge => (
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-brand-400" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd"
                  d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                  clip-rule="evenodd" />
              </svg>
              {badge}
            </div>
          ))}
        </div>
      </div>

      <!-- Right: Hero Image + Quick Quote Form stacked -->
      <div class="flex flex-col gap-6">
        <!-- Placeholder hero image — replace src with real photo -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl aspect-[4/3] bg-navy-800 flex items-center justify-center">
          <img
            src="/images/hero-garage-junk.jpg"
            alt="Arizona home garage full of junk before Fill & Haul removal"
            class="w-full h-full object-cover"
            loading="eager"
            width="600"
            height="450"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <!-- Fallback placeholder shown when image not yet uploaded -->
          <div class="absolute inset-0 hidden flex-col items-center justify-center bg-navy-700/80 text-white/60 text-center p-6">
            <svg class="w-16 h-16 mb-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-sm font-medium">Hero image placeholder</p>
            <p class="text-xs mt-1 opacity-60">Upload to /public/images/hero-garage-junk.jpg</p>
          </div>
        </div>

        <!-- Quick-quote mini form (desktop) -->
        <div class="hidden lg:block">
          <div class="bg-white rounded-2xl p-8 form-glow">
            <h3 class="font-heading font-bold text-2xl text-navy-900 mb-2">Get Your Free Estimate</h3>
            <p class="text-navy-500 text-sm mb-6">Fill out the form and we'll get back to you within the hour.</p>

            <form id="hero-form" class="space-y-4" data-form="hero">
              <input type="text" name="name" placeholder="Your Name *" required
                class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition text-sm" />
              <input type="email" name="email" placeholder="Email Address *" required
                class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition text-sm" />
              <input type="text" name="location" placeholder="Neighborhood / Zip Code *" required
                class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition text-sm" />
              <select name="job_size" required
                class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition text-sm text-navy-500">
                <option value="" disabled selected>Size of Job *</option>
                <option value="small">Small — A few items</option>
                <option value="medium">Medium — Partial room / garage</option>
                <option value="large">Large — Full room cleanout</option>
                <option value="xl">XL — Whole property / estate</option>
              </select>
              <button type="submit"
                class="w-full bg-brand-500 hover:bg-brand-600 text-white font-semibold py-3.5 rounded-lg transition text-sm cursor-pointer">
                Request Free Estimate →
              </button>
            </form>

            <p class="text-xs text-navy-400 mt-4 text-center">No spam. We typically respond within 1 hour.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
