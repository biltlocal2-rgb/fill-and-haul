---
// Navbar component
// transparent: if true, starts clear and goes opaque on scroll (hero pages)
// if false, always shows the navy background (service/interior pages)
interface Props {
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
---

<nav id="navbar" class={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${transparent ? 'bg-transparent' : 'bg-navy-900/95 backdrop-blur-sm shadow-lg'}`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-20">

      <!-- Logo -->
      <a href="/" class="flex items-center space-x-2 flex-shrink-0">
        <!-- Hauling trailer icon in brand orange, no background box -->
        <svg class="w-9 h-9 text-brand-500" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
          <!-- Trailer body -->
          <rect x="2" y="7" width="15" height="8" rx="1.5" />
          <!-- Hitch bar -->
          <line x1="17" y1="11" x2="22" y2="11" />
          <!-- Hitch ball -->
          <circle cx="22" cy="11" r="1" />
          <!-- Left wheel -->
          <circle cx="6" cy="17" r="2" />
          <!-- Right wheel -->
          <circle cx="13" cy="17" r="2" />
        </svg>
        <span class="font-heading font-extrabold text-xl nav-logo-text text-white">Fill &amp; Haul</span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-5 flex-shrink-0">
        <a href="/" class="text-sm font-medium text-white/80 hover:text-white transition whitespace-nowrap">Home</a>

        <!-- Services dropdown -->
        <div class="relative group">
          <button class="text-sm font-medium text-white/80 hover:text-white transition whitespace-nowrap flex items-center gap-1">
            Services
            <svg class="w-3.5 h-3.5 transition group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <!-- Dropdown -->
          <div class="absolute top-full left-0 mt-2 w-56 bg-navy-900/98 backdrop-blur-sm rounded-xl shadow-xl border border-white/10 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/tempe-hauling-services/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
              All Services
            </a>
            <a href="/tempe/junk-removal/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              Junk Removal
            </a>
            <a href="/tempe/debris-removal/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>
              Debris Removal
            </a>
            <a href="/tempe/construction-debris-removal/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
              Construction Debris
            </a>
            <a href="/tempe/yard-waste-hauling/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
              Yard Waste Hauling
            </a>
            <a href="/tempe/furniture-appliance-removal/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
              Furniture &amp; Appliance
            </a>
          </div>
        </div>

        <!-- Resources dropdown -->
        <div class="relative group">
          <button class="text-sm font-medium text-white/80 hover:text-white transition whitespace-nowrap flex items-center gap-1">
            Resources
            <svg class="w-3.5 h-3.5 transition group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <!-- Dropdown -->
          <div class="absolute top-full left-0 mt-2 w-48 bg-navy-900/98 backdrop-blur-sm rounded-xl shadow-xl border border-white/10 py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            <a href="/blog/" class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/80 hover:text-white hover:bg-white/10 transition">
              <svg class="w-4 h-4 text-brand-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              Blog
            </a>
            <div class="flex items-center gap-2 px-4 py-2.5 text-sm text-white/40 cursor-default">
              <svg class="w-4 h-4 text-white/30 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>
              <span>News <span class="text-xs text-brand-400/60 ml-1">Coming Soon</span></span>
            </div>
          </div>
        </div>

        <a href="tel:6026325794" class="text-sm font-medium text-white/80 hover:text-white transition whitespace-nowrap">(602)-632-5794</a>
        <a href="#contact"
          class="flex-shrink-0 bg-brand-500 hover:bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg transition text-sm whitespace-nowrap">
          Get Free Quote
        </a>
      </div>

      <!-- Mobile Click-to-Call Button (mobile/tablet only) -->
      <a href="tel:+16026325794"
        class="lg:hidden flex items-center gap-1.5 bg-brand-500 hover:bg-brand-600 text-white text-sm font-semibold px-3 py-2 rounded-lg transition">
        <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
        </svg>
        <span>(602) 632-5794</span>
      </a>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden text-white p-2" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>

    </div>

    <!-- Mobile Nav -->
    <div id="mobile-menu" class="lg:hidden hidden pb-4">
      <div class="flex flex-col space-y-1">
        <a href="/" class="mobile-link text-white/80 hover:text-white transition px-2 py-2">Home</a>
        <a href="/tempe-hauling-services/" class="mobile-link text-white/80 hover:text-white transition px-2 py-2 font-medium">All Services</a>
        <a href="/tempe/junk-removal/" class="mobile-link text-white/60 hover:text-white transition px-4 py-1.5 text-sm">- Junk Removal</a>
        <a href="/tempe/debris-removal/" class="mobile-link text-white/60 hover:text-white transition px-4 py-1.5 text-sm">- Debris Removal</a>
        <a href="/tempe/construction-debris-removal/" class="mobile-link text-white/60 hover:text-white transition px-4 py-1.5 text-sm">- Construction Debris</a>
        <a href="/tempe/yard-waste-hauling/" class="mobile-link text-white/60 hover:text-white transition px-4 py-1.5 text-sm">- Yard Waste Hauling</a>
        <a href="/tempe/furniture-appliance-removal/" class="mobile-link text-white/60 hover:text-white transition px-4 py-1.5 text-sm">- Furniture &amp; Appliance</a>
        <!-- Resources Section in Mobile -->
        <div class="border-t border-white/10 mt-1 pt-1">
          <span class="px-2 py-1 text-xs font-semibold text-white/40 uppercase tracking-wider">Resources</span>
          <a href="/blog/" class="mobile-link text-white/80 hover:text-white transition px-4 py-1.5 text-sm block">- Blog</a>
          <span class="px-4 py-1.5 text-sm text-white/30 flex items-center gap-1">- News <span class="text-xs text-brand-400/60">Coming Soon</span></span>
        </div>
        <a href="tel:6026325794" class="mobile-link text-white/80 hover:text-white transition px-2 py-2">(602)-632-5794</a>
        <a href="#contact" class="mobile-link bg-brand-500 hover:bg-brand-600 text-white font-semibold px-5 py-2.5 rounded-lg transition text-center mt-2">
          Get Free Quote
        </a>
      </div>
    </div>

  </div>
</nav>

<script define:vars={{ transparent }}>
  const navbar = document.getElementById('navbar');

  if (transparent) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar?.classList.add('bg-navy-900/95', 'backdrop-blur-sm', 'shadow-lg');
        navbar?.classList.remove('bg-transparent');
      } else {
        navbar?.classList.remove('bg-navy-900/95', 'backdrop-blur-sm', 'shadow-lg');
        navbar?.classList.add('bg-transparent');
      }
    });
  }

  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
