---
const benefits = [
  {
    color: 'green',
    bgClass: 'bg-green-50',
    iconClass: 'text-green-600',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Fast Turnaround',
    desc: 'Same-day and next-day service available. We work around your schedule, not the other way around.',
  },
  {
    color: 'blue',
    bgClass: 'bg-blue-50',
    iconClass: 'text-blue-600',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
    title: 'Licensed & Insured',
    desc: 'Fully licensed and insured for your peace of mind. Your property is protected from start to finish.',
  },
  {
    color: 'purple',
    bgClass: 'bg-purple-50',
    iconClass: 'text-purple-600',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Upfront Pricing',
    desc: 'No surprise fees. We quote you a fair price before we start and stick to it. Simple as that.',
  },
  {
    color: 'brand',
    bgClass: 'bg-brand-50',
    iconClass: 'text-brand-600',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />`,
    title: 'Eco-Friendly Disposal',
    desc: 'We recycle and donate whenever possible. Less landfill, more responsibility — it\'s the right thing to do.',
  },
];

const audiences = [
  { emoji: '🏠', label: 'Homeowners', desc: 'Declutter, renovate, or move — we make it painless.' },
  { emoji: '🔑', label: 'Realtors', desc: 'Fast property cleanouts to get listings market-ready.' },
  { emoji: '🏢', label: 'Property Managers', desc: 'Reliable partner for tenant turnovers and maintenance.' },
];
---

<section class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Benefits list -->
      <div class="fade-in">
        <span class="inline-block text-brand-600 font-semibold text-sm uppercase tracking-wider mb-3">Why Fill &amp; Haul</span>
        <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-navy-900 mb-6">
          The Valley's Most Trusted Hauling Team
        </h2>
        <p class="text-navy-500 text-lg mb-10 leading-relaxed">
          We're not a franchise or a faceless national chain. We're a local Arizona crew that treats your property like our own.
        </p>

        <div class="space-y-6">
          {benefits.map(b => (
            <div class="flex gap-4">
              <div class:list={['w-12 h-12 rounded-xl flex items-center justify-center shrink-0', b.bgClass]}>
                <svg class:list={['w-6 h-6', b.iconClass]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={b.icon} />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-navy-900 mb-1">{b.title}</h4>
                <p class="text-navy-500 text-sm">{b.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Audience card -->
      <div class="fade-in">
        <div class="bg-navy-900 rounded-3xl p-10 lg:p-12 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-brand-500/10 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
          <div class="relative z-10">
            <h3 class="font-heading font-extrabold text-3xl mb-8">Built for Pros &amp;&nbsp;Homeowners</h3>

            <div class="space-y-6">
              {audiences.map(a => (
                <div class="flex items-center gap-4 p-4 bg-white/5 rounded-xl">
                  <div class="text-3xl">{a.emoji}</div>
                  <div>
                    <div class="font-semibold">{a.label}</div>
                    <div class="text-sm text-navy-300">{a.desc}</div>
                  </div>
                </div>
              ))}
            </div>

            <div class="mt-8 pt-8 border-t border-white/10">
              <a href="#contact"
                class="inline-flex items-center text-brand-400 font-semibold hover:text-brand-300 transition">
                Get your free estimate today
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
