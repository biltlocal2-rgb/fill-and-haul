---
const services = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />`,
    title: 'Furniture Removal',
    href: '/tempe/furniture-appliance-removal/',
    desc: 'Old couches, mattresses, tables, desks â we\'ll haul away any unwanted furniture quickly and responsibly.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    title: 'Property Cleanouts',
    href: '/tempe/junk-removal/',
    desc: 'Full cleanouts for estate sales, rental turnovers, or foreclosures. Perfect for realtors and property managers.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
    title: 'Appliance Hauling',
    href: '/tempe/furniture-appliance-removal/',
    desc: 'Refrigerators, washers, dryers, ovens â we safely remove and dispose of old appliances.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Yard Waste & Debris',
    href: '/tempe/yard-waste-hauling/',
    desc: 'Tree trimmings, landscaping waste, dirt, rocks, and general yard debris picked up and hauled away.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />`,
    title: 'Construction Debris',
    href: '/tempe/construction-debris-removal/',
    desc: 'Drywall, lumber, concrete, roofing materials â we clear construction and renovation debris fast.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" />`,
    title: 'Garage & Storage',
    href: '/tempe/junk-removal/',
    desc: 'Overflowing garage or storage unit? We\'ll clear it out top to bottom and leave it spotless.',
  },
];
---

<section id="services" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 fade-in">
      <span class="inline-block text-brand-600 font-semibold text-sm uppercase tracking-wider mb-3">What We Haul</span>
      <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-navy-900 mb-4">
        Hauling Services for Every Need
      </h2>
      <p class="text-navy-500 max-w-2xl mx-auto text-lg">
        From a single piece of furniture to a full property cleanout â we handle it all with speed and care.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {services.map(s => (
        <a href={s.href} class="service-card bg-white border border-navy-100 rounded-2xl p-7 fade-in block hover:border-brand-300 hover:shadow-lg transition-all">
          <div class="w-14 h-14 bg-brand-50 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-7 h-7 text-brand-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={s.icon} />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-xl text-navy-900 mb-2">{s.title}</h3>
          <p class="text-navy-500 text-sm leading-relaxed">{s.desc}</p>
          <span class="inline-block mt-4 text-brand-600 text-sm font-semibold">Learn more →</span>
        </a>
      ))}
    </div>
  </div>
</section>
