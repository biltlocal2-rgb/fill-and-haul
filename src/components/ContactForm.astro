---
// Full lead-capture form — submits to /api/contact (Cloudflare Pages Function)
// Email delivery powered by Resend — see functions/api/contact.js for setup guide
---

<section id="contact" class="py-20 lg:py-28 bg-navy-900 relative overflow-hidden" style="background-color: #102a43">
  <div class="absolute inset-0 hero-pattern"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-brand-500/10 rounded-full blur-3xl"></div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center mb-12 fade-in">
      <span class="inline-block text-brand-400 font-semibold text-sm uppercase tracking-wider mb-3">Free Estimate</span>
      <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-white mb-4">Ready to Clear the Clutter?</h2>
      <p class="text-navy-300 text-lg max-w-xl mx-auto">
        Tell us about your job and we'll get back to you within the hour with a free, no-obligation estimate.
      </p>
    </div>

    <div class="bg-white rounded-2xl p-8 md:p-10 form-glow fade-in">

      <!-- Contact Form -->
      <form id="main-form" class="space-y-5" novalidate>
        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5">Your Name *</label>
            <input type="text" name="name" required placeholder="John Smith"
              class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5">Company Name</label>
            <input type="text" name="company" placeholder="Optional"
              class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5">Email Address *</label>
            <input type="email" name="email" required placeholder="you@email.com"
              class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5">Phone Number</label>
            <input type="tel" name="phone" placeholder="(602) 555-0123"
              class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition" />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5">Location / Zip Code *</label>
            <input type="text" name="location" required placeholder="Scottsdale / 85251"
              class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition" />
          </div>
          <div>
            <label class="block text-sm font-medium text-navy-700 mb-1.5">Size of Job *</label>
            <select name="job_size" required
              class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition">
              <option value="" disabled selected>Select size...</option>
              <option value="small">Small — A few items</option>
              <option value="medium">Medium — Partial room / garage</option>
              <option value="large">Large — Full room cleanout</option>
              <option value="xl">XL — Whole property / estate</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium text-navy-700 mb-1.5">Tell Us More</label>
          <textarea name="message" rows="3"
            placeholder="What do you need hauled? Any details help us give you an accurate quote..."
            class="w-full px-4 py-3 rounded-lg border border-navy-200 focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 outline-none transition resize-none"></textarea>
        </div>

        <!-- Submit Button -->
        <button type="submit" id="submit-btn"
          class="w-full bg-brand-500 hover:bg-brand-600 text-white font-semibold py-4 rounded-xl transition text-lg shadow-lg shadow-brand-500/30 cursor-pointer flex items-center justify-center gap-3">
          <span id="btn-text">Get My Free Estimate →</span>
          <!-- Loading spinner (hidden by default) -->
          <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
        </button>

        <!-- Inline error message (hidden by default) -->
        <div id="form-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-lg px-4 py-3 text-sm flex items-start gap-2">
          <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span id="form-error-msg">Something went wrong. Please try again or call us at (602) 632-5794.</span>
        </div>

        <p class="text-xs text-navy-400 text-center">We respect your privacy. No spam — ever.</p>
      </form>

      <!-- Success State (hidden by default, shown after successful submission) -->
      <div id="form-success" class="hidden text-center py-8">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="font-heading font-bold text-2xl text-navy-900 mb-2">Request Received!</h3>
        <p class="text-navy-500 mb-6">We'll be in touch within the hour with your free estimate. Thank you!</p>
        <a href="tel:+16026325794" class="inline-flex items-center gap-2 text-brand-500 font-semibold hover:underline">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          Or call us now: (602) 632-5794
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  const form = document.getElementById('main-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnText = document.getElementById('btn-text');
  const btnSpinner = document.getElementById('btn-spinner');
  const successPanel = document.getElementById('form-success');
  const errorPanel = document.getElementById('form-error');
  const errorMsg = document.getElementById('form-error-msg');

  function setLoading(loading: boolean) {
    if (!submitBtn || !btnText || !btnSpinner) return;
    submitBtn.disabled = loading;
    btnText.textContent = loading ? 'Sending...' : 'Get My Free Estimate →';
    btnSpinner?.classList.toggle('hidden', !loading);
  }

  function showError(msg: string) {
    if (!errorPanel || !errorMsg) return;
    errorMsg.textContent = msg;
    errorPanel.classList.remove('hidden');
    errorPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function hideError() {
    errorPanel?.classList.add('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    const data = new FormData(form);
    const payload = {
      name: (data.get('name') as string)?.trim(),
      email: (data.get('email') as string)?.trim(),
      phone: (data.get('phone') as string)?.trim(),
      company: (data.get('company') as string)?.trim(),
      location: (data.get('location') as string)?.trim(),
      job_size: data.get('job_size') as string,
      message: (data.get('message') as string)?.trim(),
    };

    // Client-side validation
    if (!payload.name || !payload.email || !payload.location || !payload.job_size) {
      showError('Please fill in all required fields (Name, Email, Location, Job Size).');
      return;
    }

    setLoading(true);

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        // Show success panel, hide form
        form.classList.add('hidden');
        successPanel?.classList.remove('hidden');
      } else {
        showError(result.error || 'Something went wrong. Please try again or call (602) 632-5794.');
      }
    } catch {
      showError('Network error. Please check your connection and try again, or call (602) 632-5794.');
    } finally {
      setLoading(false);
    }
  });
</script>
